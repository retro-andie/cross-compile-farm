 /* Copyright (C) 1987, 1989, 1992 Free Software Foundation, Inc. */
 
@@ -42,3 +47,12 @@
 #include "config.h"
 #include "obstack.h"
 
+/* BSD compat */
+#ifndef bcopy
+#  define bcopy(s,d,n)   memmove((d),(s),(n))
+#  define bzero(d,n)     memset((d),0,(n))
+#  define bcmp(a,b,n)    memcmp((a),(b),(n))
+#  define index(s,c)     strchr((s),(c))
